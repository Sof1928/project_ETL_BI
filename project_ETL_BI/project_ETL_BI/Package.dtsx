      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{49755E86-B700-4CEC-90D9-85A7710B4C37}"
          SQLTask:SqlStatementSource="SET NOCOUNT ON;&#xA;&#xA;-- 1) Vider la Fact en premier&#xA;TRUNCATE TABLE dbo.FactStockMovements;&#xA;&#xA;-- 2) Vider les dimensions&#xA;DELETE FROM dbo.DimProduct;&#xA;DELETE FROM dbo.DimStockLocation;&#xA;DELETE FROM dbo.DimMovementType;&#xA;-- NE PAS toucher DimDate ici&#xA;-- Elle sera rechargée par un Execute SQL Task dédié&#xA;&#xA;-- 3) Réinitialiser les Identity&#xA;DBCC CHECKIDENT ('dbo.DimProduct',         RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimStockLocation',   RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimMovementType',    RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.FactStockMovements', RESEED, 0);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
