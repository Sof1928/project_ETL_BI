      DTS:LocaleID="-1"
      DTS:ObjectName="DimDate"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{49755E86-B700-4CEC-90D9-85A7710B4C37}"
          SQLTask:SqlStatementSource="SET NOCOUNT ON;&#xA;&#xA;-- Recharger DimDate proprement&#xA;TRUNCATE TABLE dbo.DimDate;&#xA;&#xA;WITH DateCTE AS (&#xA;    SELECT CAST('2019-01-01' AS DATE) AS d&#xA;    UNION ALL&#xA;    SELECT DATEADD(DAY, 1, d)&#xA;    FROM DateCTE WHERE d &lt; '2030-12-31'&#xA;)&#xA;INSERT INTO dbo.DimDate (&#xA;    DateKey, FullDate, DayOfMonth, Month, MonthName,&#xA;    Quarter, Year, DayOfWeek, DayName, IsWeekend, IsHoliday&#xA;)&#xA;SELECT&#xA;    CONVERT(INT, FORMAT(d,'yyyyMMdd')),&#xA;    d,&#xA;    DAY(d),&#xA;    MONTH(d),&#xA;    DATENAME(MONTH, d),&#xA;    DATEPART(QUARTER, d),&#xA;    YEAR(d),&#xA;    DATEPART(WEEKDAY, d),&#xA;    DATENAME(WEEKDAY, d),&#xA;    CASE WHEN DATEPART(WEEKDAY,d) IN (1,7) THEN 1 ELSE 0 END,&#xA;    0&#xA;FROM DateCTE&#xA;OPTION (MAXRECURSION 5000);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
